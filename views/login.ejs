<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - E-GiziTrack</title>
    <link rel="icon" type="image/png" href="/assets/images/logo.png">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
        body{background:linear-gradient(135deg,#0f2b1d,#14532d,#166534);min-height:100vh;display:flex;justify-content:center;align-items:center;font-family:'Inter',sans-serif;color:#fff;padding:20px}
        .login-wrapper{display:flex;width:100%;max-width:1100px;justify-content:space-between;align-items:center;gap:40px}
        .stats-col{width:260px;flex-shrink:0}
        .stats-col h2{font-size:22px;margin-bottom:6px}
        .stats-col p{font-size:13px;opacity:.7;margin-bottom:24px;line-height:1.5}
        .stat-pill{background:rgba(255,255,255,.1);backdrop-filter:blur(8px);padding:16px 20px;border-radius:14px;margin-bottom:10px;text-align:center;transition:transform .2s}
        .stat-pill:hover{transform:translateY(-2px)}
        .stat-pill .num{font-size:28px;font-weight:700}
        .stat-pill .lbl{font-size:12px;opacity:.75;margin-top:2px}
        .login-card{background:#fff;color:#333;padding:36px;border-radius:20px;width:380px;flex-shrink:0;box-shadow:0 20px 50px rgba(0,0,0,.3);text-align:center}
        .login-card img{width:48px;margin-bottom:8px}
        .login-card h2{font-size:20px;color:#111;margin-bottom:2px}
        .login-card .subtitle{font-size:12px;color:#888;margin-bottom:24px}
        .field-label{text-align:left;font-size:12px;font-weight:600;margin-top:14px;color:#555}
        .field-input{width:100%;padding:11px 14px;margin-top:5px;border:1px solid #e5e7eb;border-radius:10px;font-size:14px;font-family:inherit;transition:border .2s;box-sizing:border-box}
        .field-input:focus{outline:none;border-color:#16a34a;box-shadow:0 0 0 3px rgba(22,163,74,.1)}
        .role-toggle{display:flex;gap:8px;margin:18px 0}
        .role-opt{flex:1;padding:10px;border-radius:10px;border:2px solid #e5e7eb;background:#f9fafb;cursor:pointer;font-weight:600;font-size:13px;transition:all .2s;font-family:inherit;color:#555}
        .role-opt:hover{border-color:#16a34a}
        .role-opt.active{background:#14532d;color:#fff;border-color:#14532d}
        .btn-login{width:100%;background:linear-gradient(135deg,#14532d,#166534);color:#fff;padding:12px;border:none;border-radius:10px;cursor:pointer;font-weight:700;font-size:14px;font-family:inherit;transition:opacity .2s;margin-top:6px}
        .btn-login:hover{opacity:.9}
        .forgot{margin-top:14px;font-size:11px;color:#aaa}
        .features-col{width:260px;flex-shrink:0}
        .features-col h3{font-size:16px;margin-bottom:14px}
        .feat-item{background:rgba(255,255,255,.08);backdrop-filter:blur(8px);padding:12px 18px;border-radius:28px;margin-bottom:8px;font-size:13px;display:flex;align-items:center;gap:8px;transition:transform .2s}
        .feat-item:hover{transform:translateX(4px)}
        footer{position:fixed;bottom:14px;left:0;right:0;text-align:center;font-size:11px;opacity:.5}
        @media(max-width:900px){.login-wrapper{flex-direction:column;align-items:center}.stats-col,.features-col{display:none}.login-card{width:100%;max-width:400px}}
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="stats-col">
            <h2>Selamat Datang 👋</h2>
            <p>Sistem Pendataan Kesehatan Ibu Hamil dan Balita Wilayah Pontianak</p>
            <div class="stat-pill"><div class="num"><%= totalData %></div><div class="lbl">Total Data Terkumpul</div></div>
            <div class="stat-pill"><div class="num"><%= totalWilayah %></div><div class="lbl">Wilayah Tercakup</div></div>
            <div class="stat-pill"><div class="num"><%= totalEnum %></div><div class="lbl">Enumerator Aktif</div></div>
        </div>
        <div class="login-card">
            <img src="/assets/images/logo.png" alt="Logo">
            <h2>E-GiziTrack</h2>
            <p class="subtitle">Sistem Pengumpulan Data Gizi Ibu Hamil dan Balita</p>
            <form action="/login" method="POST">
                <div class="field-label">Username</div>
                <input type="text" name="username" class="field-input" placeholder="Masukkan username" required>
                <div class="field-label">Password</div>
                <input type="password" name="password" class="field-input" placeholder="••••••••" required>
                <div class="field-label" style="margin-bottom:4px;">Masuk sebagai</div>
                <div class="role-toggle">
                    <input type="hidden" name="role" id="selected_role" value="enumerator">
                    <button type="button" class="role-opt active" onclick="setRole('enumerator',this)">Enumerator</button>
                    <button type="button" class="role-opt" onclick="setRole('admin',this)">Admin</button>
                </div>
                <button type="submit" class="btn-login">Masuk</button>
            </form>
            <p class="forgot">Lupa password? Hubungi administrator sistem</p>
        </div>
        <div class="features-col">
            <h3>Fitur Utama</h3>
            <div class="feat-item">✅ Entry data Ibu Hamil & Balita</div>
            <div class="feat-item">📊 Dashboard & Statistik Real-time</div>
            <div class="feat-item">📈 Laporan Analitik & Grafik</div>
            <div class="feat-item">📥 Ekspor Data ke Excel</div>
            <div class="feat-item">🔒 Role Admin & Enumerator</div>
        </div>
    </div>
    <footer>© 2026 E-GiziTrack — Akses terbatas untuk petugas yang berwenang</footer>
    <script>
    function setRole(role, btn) {
        document.getElementById('selected_role').value = role;
        document.querySelectorAll('.role-opt').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
    }
    </script>
</body>
</html>
