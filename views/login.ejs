<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - E-GiziTrack</title>
    <link rel="icon" type="image/png" href="/assets/images/logo.png">
    <link rel="stylesheet" href="/assets/css/app.css">
    <style>
        body {
            background-color: #14532d; /* Hijau solid sesuai contoh */
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            margin: 0;
            color: white;
            font-family: 'Inter', sans-serif;
        }

        .login-container {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 60px;
            padding: 20px;
            max-width: 1200px;
            margin: 0 auto;
        }

        /* --- Left Column: Stats --- */
        .stats-col {
            flex: 1;
            max-width: 300px;
        }
        .stats-col h2 { font-size: 28px; margin-bottom: 8px; }
        .stats-col p { font-size: 14px; opacity: 0.8; margin-bottom: 24px; line-height: 1.4; }
        
        .stat-box {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 20px;
            text-align: center;
            margin-bottom: 12px;
            backdrop-filter: blur(5px);
        }
        .stat-box h3 { font-size: 24px; margin: 0; }
        .stat-box span { font-size: 11px; opacity: 0.7; text-transform: uppercase; letter-spacing: 0.5px; }

        /* --- Center Column: Login Card --- */
        .login-card {
            background: white;
            border-radius: 24px;
            padding: 40px;
            width: 400px;
            color: #333;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
            text-align: center;
        }
        .login-card img { width: 48px; margin-bottom: 16px; }
        .login-card h1 { font-size: 22px; margin: 0; color: #14532d; }
        .login-card .subtitle { font-size: 12px; color: #666; margin: 4px 0 24px; }

        .form-group { text-align: left; margin-bottom: 16px; }
        .form-group label { display: block; font-size: 13px; font-weight: 600; margin-bottom: 6px; color: #444; }
        .form-input {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 14px;
            outline: none;
        }
        .form-input:focus { border-color: #14532d; }

        .role-selector {
            display: flex;
            background: #f3f4f6;
            padding: 4px;
            border-radius: 8px;
            margin-bottom: 20px;
        }
        .role-btn {
            flex: 1;
            padding: 10px;
            border: none;
            background: transparent;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            border-radius: 6px;
            transition: all 0.2s;
        }
        .role-btn.active { background: #1a5e37; color: white; }

        .btn-submit {
            width: 100%;
            padding: 14px;
            background: #1a5e37;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: opacity 0.2s;
        }
        .btn-submit:hover { opacity: 0.9; }
        
        .login-footer { font-size: 12px; color: #888; margin-top: 16px; }

        /* --- Right Column: Features --- */
        .features-col {
            flex: 1;
            max-width: 320px;
        }
        .features-col h3 { font-size: 18px; margin-bottom: 20px; }
        
        .feat-pill {
            display: flex;
            align-items: center;
            gap: 12px;
            background: rgba(255, 255, 255, 0.1);
            padding: 12px 20px;
            border-radius: 99px;
            margin-bottom: 10px;
            font-size: 13px;
            backdrop-filter: blur(5px);
        }
        .feat-pill svg { width: 18px; height: 18px; flex-shrink: 0; }

        footer {
            padding: 20px;
            text-align: center;
            font-size: 11px;
            opacity: 0.6;
        }

        @media (max-width: 1024px) {
            .stats-col, .features-col { display: none; }
            .login-container { justify-content: center; }
        }
    </style>
    <script src="https://code.iconify.design/3/3.1.0/iconify.min.js"></script>
</head>
<body>
    <div class="login-container">
        <!-- Left Column -->
        <div class="stats-col">
            <h2>Selamat Datang</h2>
            <p>Sistem Pendataan Kesehatan Ibu Hamil dan Balita</p>
            
            <div class="stat-box">
                <h3><%= typeof totalEntri !== 'undefined' ? totalEntri : '0' %></h3>
                <span>Total Data Terkumpul</span>
            </div>
            <div class="stat-box">
                <h3><%= typeof totalWilayah !== 'undefined' ? totalWilayah : '0' %></h3>
                <span>Wilayah Tercakup</span>
            </div>
            <div class="stat-box">
                <h3><%= typeof totalEnum !== 'undefined' ? totalEnum : '1' %></h3>
                <span>Enumerator Aktif</span>
            </div>
        </div>

        <!-- Center Column -->
        <div class="login-card">
            <img src="/assets/images/logo.png" alt="Logo">
            <h1>E-GiziTrack</h1>
            <p class="subtitle">Sistem Pengumpulan Data Ibu Hamil & Balita</p>

            <form action="/login" method="POST">
                <div class="form-group">
                    <label>Username</label>
                    <input type="text" name="username" class="form-input" placeholder="Masukkan username" required>
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input type="password" name="password" class="form-input" placeholder="Masukkan password" required>
                </div>

                <div style="text-align: left; margin-bottom: 6px;"><label style="font-size: 13px; font-weight: 600;">Masuk sebagai</label></div>
                <div class="role-selector">
                    <input type="hidden" name="role" id="roleInput" value="enumerator">
                    <button type="button" class="role-btn active" onclick="selectRole('enumerator', this)">Enumerator</button>
                    <button type="button" class="role-btn" onclick="selectRole('admin', this)">Admin</button>
                </div>

                <button type="submit" class="btn-submit">Masuk</button>
            </form>

            <div class="login-footer">
                Lupa password? Hubungi administrator
            </div>
        </div>

        <!-- Right Column -->
        <div class="features-col">
            <h3>Fitur Utama</h3>
            
            <div class="feat-pill">
                <span class="iconify" data-icon="material-symbols:pregnant-woman-rounded"></span>
                Form Multi-Step Ibu Hamil
            </div>
            <div class="feat-pill">
                <span class="iconify" data-icon="mdi:baby-face-outline"></span>
                Form Multi-Step Balita
            </div>
            <div class="feat-pill">
                <span class="iconify" data-icon="mdi:view-dashboard"></span>
                Dashboard & Statistik
            </div>
            <div class="feat-pill">
                <span class="iconify" data-icon="mdi:file-excel"></span>
                Ekspor Data (.xlsx)
            </div>
        </div>
    </div>

    <footer>
        © 2026 Sistem Pengambilan Data Gizi - Akses terbatas untuk petugas yang berwenang
    </footer>

    <script>
        function selectRole(role, btn) {
            document.getElementById('roleInput').value = role;
            document.querySelectorAll('.role-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
        }
    </script>
</body>
</html>
