<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Laporan Analitik - E-GiziTrack</title>
    <link rel="icon" type="image/png" href="/assets/images/logo.png">
    <link rel="stylesheet" href="/assets/css/app.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        .chart-grid{display:grid;grid-template-columns:3fr 2fr;gap:20px;margin-bottom:20px}
        .summary-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:20px}
        .summary-card{padding:16px;border-radius:var(--radius-md);text-align:center;background:var(--gray-50)}
        .summary-card .val{font-size:24px;font-weight:700}
        .summary-card .label{font-size:11px;color:var(--gray-500);margin-top:4px}
        @media(max-width:768px){.chart-grid{grid-template-columns:1fr}.summary-cards{grid-template-columns:1fr}}
    </style>
</head>
<body>
    <% const currentPage = 'laporan'; %>
    <%- include('partials/navbar') %>
    <div class="page-container">
        <div class="page-header"><h1>Laporan Analitik</h1><p>Visualisasi data kesehatan gizi komunitas secara menyeluruh.</p></div>
        <div class="summary-cards">
            <div class="summary-card" style="border-left:4px solid var(--blue-500);"><div class="val" style="color:var(--blue-500);"><%= totalHamil %></div><div class="label">Ibu Hamil</div></div>
            <div class="summary-card" style="border-left:4px solid var(--orange-500);"><div class="val" style="color:var(--orange-500);"><%= totalBalita %></div><div class="label">Balita</div></div>
            <div class="summary-card" style="border-left:4px solid var(--red-500);"><div class="val" style="color:var(--red-500);"><%= totalKek %></div><div class="label">Risiko KEK (LILA &lt; 23.5)</div></div>
        </div>
        <div class="chart-grid">
            <div class="card"><div class="card-body">
                <div class="card-title">Sebaran per Wilayah</div>
                <div class="card-subtitle">Perbandingan data per kecamatan</div>
                <canvas id="chartWilayah" height="140" style="margin-top:16px;"></canvas>
                <div style="overflow-x:auto;margin-top:20px;"><table class="data-table">
                    <thead><tr><th>Wilayah</th><th>Ibu Hamil</th><th>Balita</th><th>Total</th></tr></thead>
                    <tbody>
                        <% sebaran.forEach(function(r) { %>
                        <tr><td><strong><%= r._id %></strong></td><td><span class="tag tag-hamil"><%= r.jml_hamil %></span></td><td><span class="tag tag-balita"><%= r.jml_balita %></span></td><td><strong><%= r.jml_hamil + r.jml_balita %></strong></td></tr>
                        <% }); %>
                    </tbody>
                </table></div>
            </div></div>
            <div>
                <div class="card" style="margin-bottom:20px;"><div class="card-body">
                    <div class="card-title">Komposisi Data</div>
                    <div class="card-subtitle">Persentase jenis responden</div>
                    <canvas id="chartDonut" style="margin-top:12px;max-height:220px;"></canvas>
                    <% const totalAll = totalHamil + totalBalita; %>
                    <div style="margin-top:16px;display:flex;flex-direction:column;gap:8px;">
                        <% const pctHamil = totalAll > 0 ? Math.round(totalHamil/totalAll*100) : 0; %>
                        <% const pctBalita = totalAll > 0 ? Math.round(totalBalita/totalAll*100) : 0; %>
                        <div style="display:flex;justify-content:space-between;align-items:center;"><span style="display:flex;align-items:center;gap:6px;font-size:13px;"><span style="width:10px;height:10px;background:var(--blue-500);border-radius:50%;display:inline-block;"></span> Ibu Hamil</span><strong><%= totalHamil %> (<%= pctHamil %>%)</strong></div>
                        <div style="display:flex;justify-content:space-between;align-items:center;"><span style="display:flex;align-items:center;gap:6px;font-size:13px;"><span style="width:10px;height:10px;background:var(--orange-500);border-radius:50%;display:inline-block;"></span> Balita</span><strong><%= totalBalita %> (<%= pctBalita %>%)</strong></div>
                    </div>
                </div></div>
                <div class="card"><div class="card-body">
                    <div class="card-title">Status Gizi</div>
                    <div class="card-subtitle">Distribusi kondisi gizi</div>
                    <canvas id="chartStatus" style="margin-top:12px;max-height:200px;"></canvas>
                </div></div>
            </div>
        </div>
    </div>
<script>
Chart.defaults.font.family="'Inter',sans-serif";Chart.defaults.font.size=12;
new Chart(document.getElementById('chartWilayah'),{type:'bar',data:{labels:<%- JSON.stringify(sebaran.map(s=>s._id)) %>,datasets:[{label:'Ibu Hamil',data:<%- JSON.stringify(sebaran.map(s=>s.jml_hamil)) %>,backgroundColor:'#3b82f6',borderRadius:6},{label:'Balita',data:<%- JSON.stringify(sebaran.map(s=>s.jml_balita)) %>,backgroundColor:'#f59e0b',borderRadius:6}]},options:{responsive:true,plugins:{legend:{position:'bottom'}},scales:{x:{stacked:true,grid:{display:false}},y:{stacked:true,beginAtZero:true}}}});
new Chart(document.getElementById('chartDonut'),{type:'doughnut',data:{labels:['Ibu Hamil','Balita'],datasets:[{data:[<%= totalHamil %>,<%= totalBalita %>],backgroundColor:['#3b82f6','#f59e0b'],borderWidth:0,spacing:3}]},options:{cutout:'70%',plugins:{legend:{display:false}},responsive:true}});
new Chart(document.getElementById('chartStatus'),{type:'doughnut',data:{labels:<%- JSON.stringify(statusDist.map(s=>s._id||'Lainnya')) %>,datasets:[{data:<%- JSON.stringify(statusDist.map(s=>s.count)) %>,backgroundColor:['#22c55e','#ef4444','#f59e0b','#8b5cf6','#6b7280'],borderWidth:0,spacing:2}]},options:{cutout:'60%',plugins:{legend:{position:'bottom',labels:{padding:12}}},responsive:true}});
</script>
</body>
</html>
